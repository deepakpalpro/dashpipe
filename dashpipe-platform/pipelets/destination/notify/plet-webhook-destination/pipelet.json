  "category": "Destination",
  "description": "POST JSON to a REST connector baseUrl + path (webhook / HTTP sink).",
  "requiredDeploymentKeys": ["region"],
  "requiredExecutionKeys": ["path"],
  "deploymentConfiguration": { "cloud": "aws", "region": "" },
  "executionConfiguration": {
    "path": "",
    "method": "POST",
    "bodyKey": "",
    "timeoutMs": "30000"
  },
  "connectorType": "rest",
  "env": {
    "CONNECTOR_CONFIG": "REST connector JSON (required: baseUrl)",
    "SERVICE_CONFIG": "Auth service JSON (optional: api_key, bearerToken)",
